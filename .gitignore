# Uploaded binary files (not tracked in git)
data/template-files/
data/guidance/files/
data/bcm-files/
data/governance-files/
data/legal/

# SQLite database (generated from JSON seed on first run)
data/isms.db
data/isms.db-shm
data/isms.db-wal

